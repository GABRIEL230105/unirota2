generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RideType {
  OFERTA
  SOLICITACAO
}

enum RideStatus {
  PENDENTE
  ACEITA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

enum ParticipantStatus {
  CONFIRMADA
  CANCELADA
}

model User {
  id String @id @default(uuid())

  name     String
  email    String @unique
  password String

  course String
  shift  String

  bio    String?
  avatar String?

  // Recuperação de senha
  resetToken    String?
  resetTokenExp DateTime?

  // dados do veículo (só relevante se o aluno também oferece carona)
  vehicleModel String?
  vehicleColor String?
  plate        String?

  verified Boolean @default(false)

  // caronas que este usuário publicou (motorista/autor)
  rides Ride[] @relation("RideAuthor")

  // caronas em que este usuário é o passageiro fixo do Ride
  ridesAsPassenger Ride[] @relation("RidePassenger")

  rideParticipants RideParticipant[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  sentRatings     Rating[] @relation("SentRatings")
  receivedRatings Rating[] @relation("ReceivedRatings")

  notifications Notification[]
  activities    Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ride {
  id String @id @default(uuid())

  type RideType

  origin      String
  destination String

  bairro String?
  rua    String?
  numero String?

  latitude  Float?
  longitude Float?

  date String?
  time String?

  seats Int?
  price Float?

  observation String?

  status RideStatus @default(PENDENTE)

  // posição em tempo real de quem está a caminho (o motorista/quem aceitou)
  currentLat        Float?
  currentLng        Float?
  locationUpdatedAt DateTime?

  // posição em tempo real de quem solicitou a carona (pra o motorista acompanhar também)
  requesterLat               Float?
  requesterLng               Float?
  requesterLocationUpdatedAt DateTime?

  // coordenadas do destino final, usadas pra traçar a rota depois que a corrida começa
  destinationLatitude  Float?
  destinationLongitude Float?

  userId String
  user   User   @relation("RideAuthor", fields: [userId], references: [id])

  passengerId String?
  passenger   User?   @relation("RidePassenger", fields: [passengerId], references: [id])

  participants RideParticipant[]
  ratings      Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RideParticipant {
  id String @id @default(uuid())

  status ParticipantStatus @default(CONFIRMADA)

  rideId String
  ride   Ride   @relation(fields: [rideId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rideId, userId])
}

model Message {
  id String @id @default(uuid())

  content String
  read    Boolean @default(false)

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rating {
  id String @id @default(uuid())

  score   Int
  comment String?

  rideId String
  ride   Ride   @relation(fields: [rideId], references: [id])

  evaluatorId String
  evaluator   User   @relation("SentRatings", fields: [evaluatorId], references: [id])

  evaluatedId String
  evaluated   User   @relation("ReceivedRatings", fields: [evaluatedId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rideId, evaluatorId, evaluatedId])
}

model Notification {
  id String @id @default(uuid())

  title   String
  message String
  type    String
  read    Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id String @id @default(uuid())

  action String
  detail String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
